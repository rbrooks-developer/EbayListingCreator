# ── Supabase (user accounts) ───────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ── eBay Developer Credentials ─────────────────────────────────────────────────
# These are YOUR developer app credentials, not the end-user's.
# Get them from: https://developer.ebay.com/my/keys
#
# IMPORTANT: These values are baked into the JavaScript bundle at build time.
# Use a Production keyset for live use, or a Sandbox keyset for testing.
#
# For each environment you need three values from the eBay Developer Portal:
#   App ID (Client ID)   → VITE_EBAY_CLIENT_ID
#   Cert ID (Secret)     → VITE_EBAY_CLIENT_SECRET
#   RuName               → VITE_EBAY_RUNAME
#
# The RuName is the "Redirect URL name" registered under your app's OAuth settings.
# Register two redirect URLs in the eBay developer portal:
#   Production:  https://your-username.github.io/EbayListingCreator/
#   Local dev:   http://localhost:5173/
# eBay gives each registered URL a RuName like "YourName-YourApp-PRD-xxxxxxx".

# Production keyset
VITE_EBAY_CLIENT_ID=YourApp-PRD-xxxxxxxxxxxxxxxx
VITE_EBAY_CLIENT_SECRET=PRD-xxxxxxxxxxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VITE_EBAY_RUNAME=YourName-YourApp-PRD-xxxxxxxx

# Sandbox keyset (optional — only needed when using the Sandbox toggle)
VITE_EBAY_SANDBOX_CLIENT_ID=YourApp-SBX-xxxxxxxxxxxxxxxx
VITE_EBAY_SANDBOX_CLIENT_SECRET=SBX-xxxxxxxxxxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VITE_EBAY_SANDBOX_RUNAME=YourName-YourApp-SBX-xxxxxxxx

# ── Supabase social auth setup checklist ──────────────────────────────────────
# Dashboard → Authentication → Providers
#
#   Google:   console.cloud.google.com → APIs & Services → OAuth 2.0 Client ID
#             Redirect URI: https://your-project.supabase.co/auth/v1/callback
#
#   GitHub:   github.com/settings/developers → OAuth Apps → New OAuth App
#             Callback: https://your-project.supabase.co/auth/v1/callback
#
#   Discord:  discord.com/developers (coming soon)
#   LinkedIn: linkedin.com/developers (coming soon)
#
# Add your site URL to Supabase → Auth → URL Configuration → Redirect URLs:
#   https://your-username.github.io/EbayListingCreator/
#   http://localhost:5173/
